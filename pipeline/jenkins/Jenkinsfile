pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: jnlp
    image: jenkins/inbound-agent:3355.v388858a_47b_33-20
  - name: checkov
    image: bridgecrew/checkov:latest
    command: ['cat']
    tty: true
  - name: tflint
    image: ghcr.io/terraform-linters/tflint:latest
    command: ['cat']
    tty: true
"""
        }
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Security Scan') {
            steps {
                container('checkov') {
                    // checkov busca archivos de infraestructura. 
                    // Como aún no tenemos Terraform, esto probablemente dará un warning
                    // de "no se encontraron archivos", pero probará que la herramienta corre.
                    sh 'checkov --version'
                }
            }
        }
        stage('Lint Infrastructure') {
            steps {
                container('tflint') {
                    sh 'tflint --version'
                }
            }
        }
    }
}

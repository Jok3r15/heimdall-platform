pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins/label: "heimdall-core-pipeline"
spec:
  containers:
  - name: terraform
    image: hashicorp/terraform:latest
    command: ['cat']
    tty: true
  - name: checkov
    image: bridgecrew/checkov:latest
    command: ['cat']
    tty: true
  - name: tflint
    image: ghcr.io/terraform-linters/tflint:latest
    command: ['cat']
    tty: true
"""
        }
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Security Scan') {
            steps {
                container('checkov') {
                    sh '''
                    checkov -d infrastructure/terraform/test \
                    --skip-check CKV_AWS_18,CKV_AWS_144,CKV_AWS_145,CKV2_AWS_62
                    '''
                }
            }
        }
        stage('Lint Infrastructure') {
            steps {
                container('tflint') {
                    sh '''
                    cd infrastructure/terraform/test
                    tflint --init
                    tflint
                    '''
                }
            }
        }
        stage('Terraform Plan') {
            steps {
                container('terraform') {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials-id']]) {
                        sh '''
                        cd infrastructure/terraform/test
                        terraform init
                        terraform plan
                        '''
                    }
                }
            }
        }
    }
    post {
        always {
            container('terraform') {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials-id']]) {
                    echo "Executing cleanup (destroy)..."
                    sh '''
                    cd infrastructure/terraform/test
                    terraform init
                    terraform destroy -auto-approve
                    '''
                }
            }
        }
        failure {
            script {
                withCredentials([string(credentialsId: 'slack-webhook-url', variable: 'SLACK_URL')]) {
                    def msg = "🚨 *Pipeline Failed* | Job: ${env.JOB_NAME} | Build: #${env.BUILD_NUMBER}\n🔗 <${env.BUILD_URL}|View details in Jenkins>"
                    sh "curl -X POST -H 'Content-type: application/json' --data '{\"text\":\"${msg}\"}' \$SLACK_URL"
                }
            }
        }
    }
}

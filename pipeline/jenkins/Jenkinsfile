pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins/label: "heimdall-core-pipeline"
spec:
  containers:
  - name: terraform
    image: hashicorp/terraform:latest
    command: ['cat']
    tty: true
  - name: checkov
    image: bridgecrew/checkov:latest
    command: ['cat']
    tty: true
  - name: tflint
    image: ghcr.io/terraform-linters/tflint:latest
    command: ['cat']
    tty: true
"""
        }
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Security Scan') {
            steps {
                container('checkov') {
                    sh 'checkov -d infrastructure/terraform/test'
                }
            }
        }
        stage('Lint Infrastructure') {
            steps {
                container('tflint') {
                    sh 'tflint --init'
                    sh 'tflint'
                }
            }
        }
        stage('Terraform Plan') {
            steps {
                container('terraform') {
                    // Aquí usamos la credencial que acabas de crear
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials-id']]) {
                        sh '''
                        terraform init
                        terraform plan
                        '''
                    }
                }
            }
        }
    }
    post {
        failure {
            script {
                withCredentials([string(credentialsId: 'slack-webhook-url', variable: 'SLACK_URL')]) {
                    def msg = "🚨 *Fallo en Pipeline* | Job: ${env.JOB_NAME} | Build: #${env.BUILD_NUMBER}\n🔗 <${env.BUILD_URL}|Ver detalles en Jenkins>"
                    sh "curl -X POST -H 'Content-type: application/json' --data '{\"text\":\"${msg}\"}' \$SLACK_URL"
                }
            }
        }
        success {
            script {
                withCredentials([string(credentialsId: 'slack-webhook-url', variable: 'SLACK_URL')]) {
                    def msg = "✅ *Pipeline Exitoso* | Job: ${env.JOB_NAME} | Build: #${env.BUILD_NUMBER}\n🔗 <${env.BUILD_URL}|Ver reporte completo>"
                    sh "curl -X POST -H 'Content-type: application/json' --data '{\"text\":\"${msg}\"}' \$SLACK_URL"
                }
            }
        }
    }
}
